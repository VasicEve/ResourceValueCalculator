<Window x:Class="ResourceValueCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ResourceValueCalculator"
        mc:Ignorable="d"
        Title="Resource Value Calculator" Height="600" Width="920"
        d:DataContext="{d:DesignInstance Type=local:ShellViewModel}">
    <TabControl Margin="8">
        <TabControl.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </TabControl.Resources>

        <!-- ============================ Calculator tab ============================ -->
        <TabItem Header="Resource Value Calculator">
            <Grid DataContext="{Binding Calculator}" Margin="12"
                  d:DataContext="{d:DesignInstance Type=local:CalculatorViewModel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Price = (Base Price × SCU Qty) × Base Quality × Profit Margin"
                               Foreground="Gray"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#0A66C2"
                               FontStyle="Italic" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Resources}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionUnit="Cell"
                          BorderBrush="#DDDDDD" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Resource" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Margin="2"
                                              ItemsSource="{Binding DataContext.Catalog,
                                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedItem="{Binding SelectedCommodity, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              TextSearch.TextPath="Name"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              StaysOpenOnEdit="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Base Price" Width="130"
                                            Binding="{Binding BasePrice, StringFormat=0.######}"/>
                        <DataGridTextColumn Header="SCU Qty" Width="110"
                                            Binding="{Binding ScuQty, StringFormat=0.######}"/>
                        <DataGridTextColumn Header="Base Quality" Width="110"
                                            Binding="{Binding BaseQuality, StringFormat=0.######}"/>
                        <DataGridTextColumn Header="Price" Width="150" IsReadOnly="True"
                                            Binding="{Binding Price, StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remove" Margin="4,2" Padding="6,1"
                                            Command="{Binding DataContext.RemoveCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="2" Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Profit Margin (×)" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding ProfitMargin, StringFormat=0.######}"
                                 Width="80" Padding="4,2" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <Button Content="+ Add Resource" HorizontalAlignment="Left" Padding="14,6"
                            Command="{Binding AddCommand}"/>
                </DockPanel>

                <Border Grid.Row="3" Margin="0,12,0,0" Padding="14,10"
                        Background="#F2F4F5" CornerRadius="4">
                    <DockPanel>
                        <TextBlock Text="Total Value" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding GrandTotal, StringFormat=N2}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="22" FontWeight="Bold" Foreground="#1A7F37"/>
                    </DockPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================ Components tab ============================ -->
        <TabItem Header="Components">
            <Grid DataContext="{Binding Components}" Margin="12"
                  d:DataContext="{d:DesignInstance Type=local:ComponentViewModel}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Resources required to craft a component (quantities fixed by the blueprint, priced from UEX)."
                               Foreground="Gray" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#0A66C2"
                               FontStyle="Italic" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Category" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="190" Margin="0,0,16,0"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"/>
                        <TextBlock Text="Component" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="380"
                                  ItemsSource="{Binding FilteredBlueprints}"
                                  SelectedItem="{Binding SelectedBlueprint}"
                                  DisplayMemberPath="Name"
                                  TextSearch.TextPath="Name"
                                  IsEditable="True"
                                  IsTextSearchEnabled="True"/>
                    </StackPanel>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Resources}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          BorderBrush="#DDDDDD" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Resource" Width="*" IsReadOnly="True"
                                            Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Base Price" Width="130" IsReadOnly="True"
                                            Binding="{Binding BasePrice, StringFormat=N2}"/>
                        <DataGridTextColumn Header="SCU Qty" Width="110" IsReadOnly="True"
                                            Binding="{Binding ScuQty, StringFormat=0.######}"/>
                        <!-- Editable: adjust each material's quality to see its effect on value -->
                        <DataGridTextColumn Header="Base Quality" Width="120"
                                            Binding="{Binding BaseQuality, StringFormat=0.######}">
                            <DataGridTextColumn.CellStyle>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                    <Setter Property="Background" Value="#FFFCF3D8"/>
                                    <Setter Property="ToolTip" Value="Editable — adjust this material's quality"/>
                                </Style>
                            </DataGridTextColumn.CellStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Price" Width="150" IsReadOnly="True"
                                            Binding="{Binding Price, StringFormat=N2}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="2" Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Profit Margin (×)" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding ProfitMargin, StringFormat=0.######}"
                                 Width="80" Padding="4,2" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Resources &amp; quantities are fixed by the blueprint — edit Base Quality to adjust."
                               Foreground="Gray" VerticalAlignment="Center"/>
                </DockPanel>

                <Border Grid.Row="3" Margin="0,12,0,0" Padding="14,10"
                        Background="#F2F4F5" CornerRadius="4">
                    <DockPanel>
                        <TextBlock Text="Total Resource Value" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding GrandTotal, StringFormat=N2}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="22" FontWeight="Bold" Foreground="#1A7F37"/>
                    </DockPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- ============================ Update Data tab ============================ -->
        <TabItem Header="Update Data">
            <Grid DataContext="{Binding Import}" Margin="16"
                  d:DataContext="{d:DesignInstance Type=local:ImportViewModel}">
                <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                    <TextBlock Text="Update component blueprints" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#444444"
                               Text="Fetches the latest crafting blueprints from the scunpacked-data project (datamined Star Citizen game files) on GitHub, distills each blueprint's bill of materials, and updates the Components tab. The imported data is saved locally and reused on the next launch."/>
                    <TextBlock Text="Source (GitHub):" FontWeight="SemiBold" Margin="0,12,0,0" Foreground="#444444"/>
                    <TextBlock Text="{Binding SourceUrl, Mode=OneWay}" Foreground="Gray" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
                        <Button Content="Import latest from GitHub" Padding="16,8" FontWeight="SemiBold"
                                Command="{Binding ImportCommand}"/>
                        <ProgressBar Width="180" Height="14" Margin="14,0,0,0" IsIndeterminate="True"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,16,0,0" TextWrapping="Wrap"
                               Foreground="#0A66C2" FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
